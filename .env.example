# ============================================================
# Örnek ortam değişkenleri — .env.local olarak kopyalayıp doldurun
# Gerçek secret'ları ASLA repoya commit etmeyin (.env.local gitignore'da)
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role anahtarı — yalnızca sunucuda, tam yetki (RLS'i bypass eder)
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=

# --- E-posta (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMIN_EMAIL=

# --- Anthropic (chatbot) ---
# Opsiyonel: tanımlıysa DB'deki anthropic_api_key yerine bu kullanılır
ANTHROPIC_API_KEY=

# --- site_settings at-rest şifreleme anahtarı ---
# QNBPay app_secret/merchant_key ve Anthropic API key veritabanında bu anahtarla
# AES-256-GCM ile şifrelenir. Tanımlıysa yeni kayıtlar şifrelenir; tanımlı değilse
# düz metin saklanır (kademeli geçiş). 32 byte: 64 hex karakter.
# Üretmek için:  openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=
